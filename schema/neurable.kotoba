// Neurable clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace neurable {

    entity Device {
        id: string @unique
        model: string
        channels: integer
        samplingHz: integer
        firmware: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Session {
        id: string @unique
        deviceId: string
        subjectRef: string
        startedAt: datetime
        durationSec: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Channel {
        id: string @unique
        deviceId: string
        label: string
        location: string
        impedanceKohm: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Signal {
        id: string @unique
        sessionId: string
        channelLabel: string
        band: string
        dataRef: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Event {
        id: string @unique
        sessionId: string
        marker: string
        offsetMs: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Calibration {
        id: string @unique
        deviceId: string
        type: string
        completedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
